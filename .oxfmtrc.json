{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "singleQuote": true,
  "tabWidth": 2,
  "printWidth": 100,
  "semi": true,
  "trailingComma": "es5",
  "arrowParens": "avoid",
  "sortPackageJson": false,
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/dist-ssr/**",
    "**/.astro/**",
    "**/.next/**",
    "**/.turbo/**",
    "**/.sst/**",
    "**/.wrangler/**",
    "**/.netlify/**",
    "**/.expo/**",
    "**/coverage/**",
    "**/routeTree.gen.ts",
    "**/generated/**",
    "**/_generated/**"
  ]
}
