#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../node_modules/pnpm/bin/pnpx.cjs" "$@"
else
  exec node  "$basedir/../node_modules/pnpm/bin/pnpx.cjs" "$@"
fi
# cmd-shim-target=C:/Users/Rey Garcia/my-projects/react-projects/bagyo-rescue/.pnpm-store/v11/links/@/pnpm/9.1.1/9c057a0812634f9b7f398f3c5d2d4aa402c4b0e4c99deab24fa93ca269d0f638/node_modules/pnpm/bin/pnpx.cjs
