# Supabase project URL used by edge functions for server-to-server calls.
# Found in Supabase Dashboard -> Project Settings -> API -> Project URL.
SUPABASE_URL=

# Public Supabase anon key. Used when an edge function acts on behalf of an
# end user (forwarded auth header).
# Found in Supabase Dashboard -> Project Settings -> API -> Project API keys -> anon public.
SUPABASE_ANON_KEY=

# Privileged Supabase service role key. Server-only -- never expose to the
# browser. Used when an edge function needs to bypass row-level security.
# Found in Supabase Dashboard -> Project Settings -> API -> Project API keys -> service_role.
SUPABASE_SERVICE_ROLE_KEY=

# HS256 secret used to sign short-lived (5 min) JWT access tokens.
# Generate with: openssl rand -base64 32
APP_AUTH_ACCESS_TOKEN_SECRET=

# HS256 secret used to sign long-lived (30 day) JWT refresh tokens.
# Use a different value than APP_AUTH_ACCESS_TOKEN_SECRET so a leak of one
# does not compromise the other.
# Generate with: openssl rand -base64 32
APP_AUTH_REFRESH_TOKEN_SECRET=
